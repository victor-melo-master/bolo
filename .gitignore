# ── CRÍTICO: Nunca commitear secretos ──────────────────────
cookies.txt
secrets/*.txt
secrets/*.key
secrets/*.pem
.env.local
.env.*.local
.env

# ── Dependencias ────────────────────────────────────────────
node_modules/
vendor/

# ── Builds ──────────────────────────────────────────────────
dist/
build/
out/
*.exe

# ── Docker ──────────────────────────────────────────────────
.docker/

# ── Logs ────────────────────────────────────────────────────
*.log
logs/

# ── IDEs ────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── OS ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.env
postgres/pgpass
