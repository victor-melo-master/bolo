# ==============================================================
# BOLO MVP – Variables de entorno NO sensibles
# Los secretos (contraseñas, tokens) van en ./secrets/*.txt
# ==============================================================

# Base de datos
POSTGRES_DB=bolo
POSTGRES_USER=bolo_admin

# pgAdmin
PGADMIN_EMAIL=admin@bolo.com

# Puertos (solo bind en 127.0.0.1)
API_PORT=3000
MIDDLEWARE_PORT=8080
FRONTEND_PORT=5173

# Entorno de ejecución
NODE_ENV=development
LOG_LEVEL=info
